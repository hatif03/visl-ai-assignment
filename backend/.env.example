# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# LLM (LiteLLM format: provider/model)
LITELLM_MODEL=gemini/gemini-2.0-flash
GEMINI_API_KEY=your-gemini-api-key
GOOGLE_API_KEY=your-google-api-key-fallback
GROQ_API_KEY=gsk_your-groq-key

# Embeddings (uses google-genai SDK directly)
EMBEDDING_MODEL=gemini-embedding-001

# GitHub
GITHUB_TOKEN=ghp_your-github-token

# Email (Gmail SMTP with App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=your-email@gmail.com

# Google Calendar (single-line JSON service account credentials)
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
GOOGLE_CALENDAR_ID=primary

# App URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
TEST_LINK_BASE_URL=https://your-test-platform.com/test
